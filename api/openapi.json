    "/api/v1/sofa": {
      "post": {
        "description": "快速計算 SOFA Score\n\nCalculate Sequential Organ Failure Assessment score.",
        "operationId": "calculate_sofa_api_v1_sofa_post",
        "parameters": [
          {
            "description": "PaO2/FiO2 ratio",
            "in": "query",
            "name": "pao2_fio2_ratio",
            "required": true,
            "schema": {
              "description": "PaO2/FiO2 ratio",
              "title": "Pao2 Fio2 Ratio",
              "type": "number"
            }
          },
          {
            "description": "Platelets (×10³/µL)",
            "in": "query",
            "name": "platelets",
            "required": true,
            "schema": {
              "description": "Platelets (×10³/µL)",
              "title": "Platelets",
              "type": "number"
            }
          },
          {
            "description": "Bilirubin (mg/dL)",
            "in": "query",
            "name": "bilirubin",
            "required": true,
            "schema": {
              "description": "Bilirubin (mg/dL)",
              "title": "Bilirubin",
              "type": "number"
            }
          },
          {
            "description": "MAP or vasopressor status",
            "in": "query",
            "name": "cardiovascular",
            "required": true,
            "schema": {
              "description": "MAP or vasopressor status",
              "title": "Cardiovascular",
              "type": "string"
            }
          },
          {
            "description": "GCS score",
            "in": "query",
            "name": "gcs_score",
            "required": true,
            "schema": {
              "description": "GCS score",
              "maximum": 15,
              "minimum": 3,
              "title": "Gcs Score",
              "type": "integer"
            }
          },
          {
            "description": "Creatinine (mg/dL)",
            "in": "query",
            "name": "creatinine",
            "required": true,
            "schema": {
              "description": "Creatinine (mg/dL)",
              "title": "Creatinine",
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Calculate Sofa Api V1 Sofa Post",
